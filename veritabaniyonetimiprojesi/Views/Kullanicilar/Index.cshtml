@model List<veritabaniyonetimiprojesi.Models.Kullanici>
@{
    ViewData["Title"] = "Kullanıcılar";
}

<div class="panel-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Kullanıcı Listesi</h4>
        <a asp-action="Ekle" class="btn btn-success">+ Yeni Kullanıcı</a>
    </div>

    <form method="get" class="mb-3">
        <input type="text" name="arama" value="@ViewBag.Arama" class="form-control" placeholder="Ad, soyad veya şehir ara" />
    </form>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ad</th>
                    <th>Soyad</th>
                    <th>Telefon</th>
                    <th>Eposta</th>
                    <th>Şehir</th>
                    <th>Durum</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.KullaniciID</td>
                        <td>@item.Ad</td>
                        <td>@item.Soyad</td>
                        <td>@item.Telefon</td>
                        <td>@item.Eposta</td>
                        <td>@item.Sehir</td>
                        <td>@item.KayitDurumu</td>
                        <td>
                            <a asp-action="Duzenle" asp-route-id="@item.KullaniciID" class="btn btn-sm btn-warning">Düzenle</a>
                            <a asp-action="Sil" asp-route-id="@item.KullaniciID"
                               onclick="return confirm('Silmek istediğine emin misin?')"
                               class="btn btn-sm btn-danger">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        @for (int i = 1; i <= ViewBag.ToplamSayfa; i++)
        {
            <a href="?sayfa=@i&arama=@ViewBag.Arama"
               class="btn btn-sm @(i == ViewBag.Sayfa ? "btn-primary" : "btn-light")">@i</a>
        }
    </div>
</div>
<div class="mt-3">
    @for (int i = 1; i <= ViewBag.ToplamSayfa; i++)
    {
        <a href="?sayfa=@i"
           class="btn btn-sm @(i == ViewBag.Sayfa ? "btn-primary" : "btn-light")">@i</a>
    }
</div>